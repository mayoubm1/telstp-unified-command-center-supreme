# TELsTP Unified Command Center Environment Configuration

# Firebase Configuration (Current Main Database)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Supabase Configuration (For OmniCog Hub Integration)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database Configuration
DATABASE_PROVIDER=mock # Options: firebase, supabase, mock
ENABLE_REALTIME=false
FALLBACK_TO_MOCK=true

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# M2-3M Integration
M2_3M_API_ENDPOINT=https://your-m2-3m-endpoint.com
M2_3M_API_KEY=your_m2_3m_api_key

# OmniCog Hub Configuration
OMNICOG_HUB_URL=https://your-omnicog-hub.vercel.app
OMNICOG_API_KEY=your_omnicog_api_key

# Vercel Deployment (for OmniCog Hub)
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_TOKEN=your_vercel_token